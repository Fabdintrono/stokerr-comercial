# Database (Supabase)
# Reemplaza [PROJECT-REF] y [PASSWORD] con tus datos de Supabase
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-eu-west-2.pooler.supabase.com:6543/postgres"

# Para migraciones, usa la conexión directa:
# DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# NextAuth
# Genera con: openssl rand -base64 32
NEXTAUTH_SECRET="tu-secret-aqui-genera-uno-nuevo"
NEXTAUTH_URL="http://localhost:3000"

# Supabase (opcional)
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="tu-anon-key"

# App
NODE_ENV="development"