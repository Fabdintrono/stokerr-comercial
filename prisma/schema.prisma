generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// STOCKER - Schema simplificado para funcionar
// ============================================

enum Role {
  SUPER_ADMIN
  WAREHOUSE_MANAGER
  RESTAURANT_MANAGER
  CASHIER
  WAITER
  USER
}

enum BusinessRole {
  OWNER
  MANAGER
  EMPLOYEE
}

enum Plan {
  STARTER
  GROWTH
  ENTERPRISE
}

enum Unit {
  KG
  G
  L
  ML
  UNIT
  BOX
  CASE
  GARRAFA
}

enum InvoiceStatus {
  DRAFT
  RECEIVED
  PAID
  CANCELLED
}

enum MovementType {
  IN
  OUT
  TRANSFER
  ADJUSTMENT
}

enum Currency {
  USD
  VES
  BRL
}

enum RateSource {
  AUTO_BCV
  AUTO_FOREX
  MANUAL
}

enum ModuleSource {
  PLAN
  ADDON
}

// ============================================
// USER & AUTH
// ============================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  phone     String?
  avatar    String?
  language  String   @default("pt-PT")
  active    Boolean  @default(true)
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  auditLogs              AuditLog[]
  cashRegisters          CashRegister[]
  inventoryMovements     InventoryMovement[]
  locations              UserLocation[]
  businesses             UserBusiness[]
  orders                 Order[]
  replenishRequested     ReplenishmentRequest[] @relation("ReplenishRequested")
  replenishReviewed      ReplenishmentRequest[] @relation("ReplenishReviewed")

  @@map("users")
}

// ============================================
// BUSINESS (Multi-tenant)
// ============================================

model Business {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  plan           Plan     @default(STARTER)
  active         Boolean  @default(true)
  maxRestaurants Int      @default(5)
  maxUsers       Int      @default(10)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Multi-moneda
  baseCurrency      Currency   @default(USD)
  secondaryCurrency Currency?
  enabledCurrencies Currency[] @default([USD])
  multiCurrency     Boolean    @default(false)
  rateSource        RateSource @default(MANUAL)

  // Branding + comprobantes (Bloque B)
  logoUrl        String?
  address        String?
  phone          String?
  taxId          String?
  docPrefix      String   @default("F-")
  docNextNumber  Int      @default(1)
  taxEnabled     Boolean  @default(false)
  defaultTaxRate Decimal  @default(0) @db.Decimal(5, 2)
  taxLabel       String   @default("IVA")

  // Relaciones
  locations            Location[]
  categories           Category[]
  brands               Brand[]
  products             Product[]
  suppliers            Supplier[]
  users                UserBusiness[]
  invoices             PurchaseInvoice[]
  recipes              Recipe[]
  auditLogs            AuditLog[]
  replenishmentRequests ReplenishmentRequest[]
  notifications        Notification[]
  exchangeRates        ExchangeRate[]
  tenantModules        TenantModule[]
  customers            Customer[]

  @@map("businesses")
}

model ExchangeRate {
  id         String     @id @default(cuid())
  businessId String
  business   Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  currency   Currency
  rate       Decimal    @db.Decimal(18, 6)
  date       DateTime   @db.Date
  source     RateSource
  createdAt  DateTime   @default(now())

  @@unique([businessId, currency, date])
  @@index([businessId, currency, date])
  @@map("exchange_rates")
}

model Module {
  id              String   @id @default(cuid())
  key             String   @unique
  name            String
  description     String?
  addOnPrice      Decimal  @default(0) @db.Decimal(18, 2)
  priceCurrency   Currency @default(USD)
  includedInPlans Plan[]   @default([])
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenantModules TenantModule[]
  @@map("modules")
}

model TenantModule {
  id                String       @id @default(cuid())
  businessId        String
  business          Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  moduleKey         String
  enabled           Boolean      @default(true)
  source            ModuleSource @default(ADDON)
  priceAtActivation Decimal?     @db.Decimal(18, 2)
  activatedAt       DateTime     @default(now())

  module Module @relation(fields: [moduleKey], references: [key], onDelete: Cascade)

  @@unique([businessId, moduleKey])
  @@index([businessId])
  @@map("tenant_modules")
}

model Customer {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name       String
  taxId      String?
  address    String?
  phone      String?
  email      String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  orders Order[]
  @@index([businessId])
  @@map("customers")
}

model UserBusiness {
  id         String       @id @default(cuid())
  userId     String
  businessId String
  role       BusinessRole @default(EMPLOYEE)
  createdAt  DateTime     @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
  @@map("user_businesses")
}

// ============================================
// LOCATIONS (Depósito, Restaurantes)
// ============================================

model Location {
  id           String  @id @default(cuid())
  name         String
  type         String // WAREHOUSE, RESTAURANT
  address      String?
  city         String?
  postalCode   String?
  phone        String?
  email        String?
  isActive     Boolean @default(true)
  businessId   String
  kitchenToken String  @unique @default(dbgenerated("gen_random_uuid()"))

  business              Business                  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  users                 UserLocation[]
  inventory             Inventory[]
  transfersFrom         Transfer[]                @relation("fromLocation")
  transfersTo           Transfer[]                @relation("toLocation")
  cashRegisters         CashRegister[]
  orders                Order[]
  tables                Table[]
  InventoryMovement     InventoryMovement[]
  replenishFrom         ReplenishmentRequest[]    @relation("ReplenishFrom")
  replenishTo           ReplenishmentRequest[]    @relation("ReplenishTo")

  @@map("locations")
}

model UserLocation {
  id         String @id @default(cuid())
  userId     String
  locationId String

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([userId, locationId])
  @@map("user_locations")
}

// ============================================
// PRODUCTS & CATEGORIES
// ============================================

model Category {
  id          String  @id @default(cuid())
  name        String
  description String?
  businessId  String
  parentId    String?
  showInPos   Boolean @default(false)

  business Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  parent   Category?  @relation("CategoryParent", fields: [parentId], references: [id])
  children Category[] @relation("CategoryParent")
  products Product[]

  @@map("categories")
}

model Brand {
  id         String  @id @default(cuid())
  name       String
  description String?
  isActive   Boolean @default(true)
  businessId String

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  products Product[]

  @@map("brands")
}

model Product {
  id          String  @id @default(cuid())
  sku         String?
  name        String
  description String?
  unit        Unit    @default(UNIT)
  minStock    Float   @default(0)
  maxStock    Float   @default(0)
  costPrice   Decimal @default(0)
  salePrice   Decimal @default(0)
  vatRate     Decimal @default(23)
  isActive    Boolean @default(true)
  showInPos   Boolean @default(false)
  categoryId  String
  businessId  String
  brandId     String?

  category              Category                   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  brand                 Brand?                     @relation(fields: [brandId], references: [id])
  business              Business                   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  inventory             Inventory[]
  movements             InventoryMovement[]
  invoiceItems          InvoiceLineItem[]
  recipeItems           RecipeItem[]
  recipe                Recipe?                    @relation("RecipeProduct")
  orderItems            OrderItem[]
  transferItems         TransferLineItem[]
  replenishmentItems    ReplenishmentRequestItem[]

  @@map("products")
}

model Inventory {
  id         String @id @default(cuid())
  quantity   Float  @default(0)
  productId  String
  locationId String

  product   Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  location  Location            @relation(fields: [locationId], references: [id], onDelete: Cascade)
  movements InventoryMovement[]

  @@unique([productId, locationId])
  @@map("inventory")
}

model InventoryMovement {
  id          String        @id @default(cuid())
  type        MovementType
  quantity    Float
  reason      String?
  productId   String
  locationId  String
  userId      String
  inventoryId String?
  createdAt   DateTime      @default(now())

  product   Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  location  Location   @relation(fields: [locationId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  inventory Inventory? @relation(fields: [inventoryId], references: [id])

  @@map("inventory_movements")
}

// ============================================
// SUPPLIERS
// ============================================

model Supplier {
  id         String  @id @default(cuid())
  name       String
  email      String?
  phone      String?
  address    String?
  city       String?
  vatNumber  String?
  isActive   Boolean @default(true)
  businessId String

  business Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invoices PurchaseInvoice[]

  @@map("suppliers")
}

// ============================================
// PURCHASE INVOICES
// ============================================

model PurchaseInvoice {
  id          String        @id @default(cuid())
  number      String
  issueDate   DateTime      @default(now())
  dueDate     DateTime?
  totalAmount Decimal       @default(0)
  totalVat    Decimal       @default(0)
  status      InvoiceStatus @default(DRAFT)
  notes       String?
  supplierId  String
  businessId  String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  supplier  Supplier          @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  business  Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  lineItems InvoiceLineItem[]

  @@map("purchase_invoices")
}

model InvoiceLineItem {
  id          String  @id @default(cuid())
  quantity    Float
  unitPrice   Decimal
  vatRate     Decimal
  totalAmount Decimal
  productId   String
  invoiceId   String

  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  invoice PurchaseInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_line_items")
}

// ============================================
// TRANSFERS
// ============================================

model Transfer {
  id             String   @id @default(cuid())
  reference      String
  status         String   @default("PENDING")
  notes          String?
  fromLocationId String
  toLocationId   String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  fromLocation Location           @relation("fromLocation", fields: [fromLocationId], references: [id], onDelete: Cascade)
  toLocation   Location           @relation("toLocation", fields: [toLocationId], references: [id], onDelete: Cascade)
  lineItems    TransferLineItem[]

  @@map("transfers")
}

model TransferLineItem {
  id         String   @id @default(cuid())
  quantity   Float
  productId  String
  transferId String

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  transfer Transfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

  @@map("transfer_line_items")
}

// ============================================
// REPLENISHMENT REQUESTS
// ============================================

model ReplenishmentRequest {
  id             String    @id @default(cuid())
  status         String    @default("PENDING") // PENDING, APPROVED, REJECTED
  notes          String?
  reviewNotes    String?
  fromLocationId String
  toLocationId   String
  businessId     String
  requestedById  String
  reviewedById   String?
  reviewedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  fromLocation Location                  @relation("ReplenishFrom", fields: [fromLocationId], references: [id])
  toLocation   Location                  @relation("ReplenishTo", fields: [toLocationId], references: [id])
  business     Business                  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  requestedBy  User                      @relation("ReplenishRequested", fields: [requestedById], references: [id])
  reviewedBy   User?                     @relation("ReplenishReviewed", fields: [reviewedById], references: [id])
  items        ReplenishmentRequestItem[]

  @@map("replenishment_requests")
}

model ReplenishmentRequestItem {
  id        String @id @default(cuid())
  quantity  Float
  requestId String
  productId String

  request ReplenishmentRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  product Product              @relation(fields: [productId], references: [id])

  @@map("replenishment_request_items")
}

// ============================================
// RECIPES (for production)
// ============================================

model Recipe {
  id          String  @id @default(cuid())
  name        String
  description String?
  yield       Float   @default(1)
  isActive    Boolean @default(true)
  productId   String  @unique
  businessId  String

  product  Product     @relation("RecipeProduct", fields: [productId], references: [id], onDelete: Cascade)
  business Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  items    RecipeItem[]

  @@map("recipes")
}

model RecipeItem {
  id        String  @id @default(cuid())
  quantity  Float
  unit      String?
  recipeId  String
  productId String

  recipe  Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("recipe_items")
}

// ============================================
// POS - ORDERS & TABLES
// ============================================

model Table {
  id         String  @id @default(cuid())
  number     String
  capacity   Int     @default(4)
  isActive   Boolean @default(true)
  locationId String
  qrToken    String  @unique @default(dbgenerated("gen_random_uuid()"))

  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  orders   Order[]

  @@map("tables")
}

model Order {
  id          String   @id @default(cuid())
  number      String
  status      String   @default("OPEN")
  totalAmount Decimal  @default(0)
  currency    Currency @default(USD)
  rateToBase  Decimal  @default(1) @db.Decimal(18, 6)
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id])
  docNumber   String?
  issuedAt    DateTime?
  notes       String?
  locationId  String
  tableId     String?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  location Location    @relation(fields: [locationId], references: [id], onDelete: Cascade)
  table    Table?      @relation(fields: [tableId], references: [id])
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items    OrderItem[]
  payments Payment[]

  @@map("orders")
}

model OrderItem {
  id         String  @id @default(cuid())
  quantity   Float
  unitPrice  Decimal
  totalPrice Decimal
  orderId    String
  productId  String

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("order_items")
}

model Payment {
  id        String   @id @default(cuid())
  amount    Decimal
  method    String   @default("CASH")
  currency   Currency @default(USD)
  rateToBase Decimal  @default(1) @db.Decimal(18, 6)
  orderId   String
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// ============================================
// CASH REGISTER
// ============================================

model CashRegister {
  id             String    @id @default(cuid())
  openedAt       DateTime  @default(now())
  closedAt       DateTime?
  openingBalance Decimal   @default(0)
  closingBalance Decimal?
  totalSales     Decimal   @default(0)
  locationId     String
  userId         String

  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("cash_registers")
}

// ============================================
// AUDIT LOG
// ============================================

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  entity     String
  entityId   String?
  oldData    String?
  newData    String?
  userId     String?
  businessId String?
  createdAt  DateTime @default(now())

  user     User?     @relation(fields: [userId], references: [id])
  business Business? @relation(fields: [businessId], references: [id])

  @@map("audit_logs")
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id         String   @id @default(cuid())
  type       String   // REPLENISHMENT_REQUEST, REPLENISHMENT_UPDATED, TRANSFER_INCOMING, LOW_STOCK
  title      String
  message    String
  read       Boolean  @default(false)
  businessId String
  locationId String?
  entityId   String?
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ============================================
// SETTINGS
// ============================================

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String

  @@map("settings")
}
